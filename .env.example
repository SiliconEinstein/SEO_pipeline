# LiteLLM Proxy 配置
# 复制此文件为 .env 并填入实际值: cp .env.example .env
LITELLM_PROXY_API_BASE=https://your-litellm-proxy.example.com
LITELLM_PROXY_API_KEY=sk-xxx

# TOS 对象存储（Lance 优化历史）
# 仅当 config.yaml 中 lance.enabled: true 时必填
TOS_ACCESS_KEY=
TOS_SECRET_KEY=

# 上传钩子（upload_optimized.py）
# 仅填写 API 前缀域名，不要带具体路径（例如 https://literature-sage.bohrium.com）
SEO_UPLOAD_API_BASE=https://api.example.com
